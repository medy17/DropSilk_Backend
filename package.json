{
  "name": "your-project-name",
  "version": "1.0.0",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "start": "bun server.ts",
    "start:prod": "node dist/server.js",
    "dev": "bun run scripts/devRunner.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "bun run scripts/resetDevDb.ts",
    "migrate": "bun run scripts/migrate.ts",
    "test": "jest --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "dependencies": {
    "@dropsilk/gossamer": "^0.7.3",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "neonctl": "^2.22.0",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "uploadthing": "^7.7.4",
    "ws": "^8.20.0",
    "yargs-parser": "^22.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "clines": "^2.0.2",
    "jest": "^30.3.0",
    "node-mocks-http": "^1.17.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
