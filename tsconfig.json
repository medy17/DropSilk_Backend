{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "moduleResolution": "node",
        "types": [
            "bun-types",
            "node"
        ],
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/**/*",
        "scripts/**/*",
        "server.ts",
        "gossamer.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests"
    ]
}
